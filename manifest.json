{
  "manifest_version": 3,
  "name": "TrueBlock & Mute",
  "version": "1.0.0",
  "minimum_chrome_version": "111",
  "description": "X (Twitter) で、自分のブロック・ミュート済みアカウント由来の投稿（リポスト・引用経由を含む）を非表示にします。データは端末内のみ・外部送信なし。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/settings/blocked/all*",
        "https://x.com/settings/muted/all*",
        "https://twitter.com/settings/blocked/all*",
        "https://twitter.com/settings/muted/all*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/storage/storage.js",
        "src/sync/sync-bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "exclude_matches": [
        "https://x.com/settings/blocked/all*",
        "https://x.com/settings/muted/all*",
        "https://twitter.com/settings/blocked/all*",
        "https://twitter.com/settings/muted/all*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/storage/storage.js",
        "src/content/content-script.js"
      ],
      "css": [
        "src/content/content-script.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://x.com/settings/blocked/all*",
        "https://x.com/settings/muted/all*",
        "https://twitter.com/settings/blocked/all*",
        "https://twitter.com/settings/muted/all*"
      ],
      "world": "MAIN",
      "js": [
        "src/sync/sync-capture.js",
        "src/sync/sync-hook.js"
      ],
      "run_at": "document_start"
    }
  ]
}
